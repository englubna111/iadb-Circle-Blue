let curStage = 0, curPillar = 'vision';

function renderStages(){
  const el = document.getElementById('stages');
  el.innerHTML = STAGES.map((s,i)=>`
    <button class="stage ${i===curStage?'active':''}" data-i="${i}" style="animation:rise .5s ease forwards;animation-delay:${i*0.07}s">
      <span class="num">${s.num}</span>
      <span class="ar">${s.ar}</span>
      <span class="en">${s.en}</span>
    </button>`).join('');
  el.querySelectorAll('.stage').forEach(b=>b.onclick=()=>{curStage=+b.dataset.i;curPillar='vision';renderStages();renderPillars();renderPanel();});
}

function renderPillars(){
  const el = document.getElementById('pillars');
  el.innerHTML = PILLARS.map(p=>`
    <button class="pillar ${p.key===curPillar?'active':''}" data-k="${p.key}">
      <span class="badge">${p.letter}</span>
      <span class="lab"><span class="ar">${p.ar}</span><span class="en">${p.en}</span></span>
    </button>`).join('');
  el.querySelectorAll('.pillar').forEach(b=>b.onclick=()=>{curPillar=b.dataset.k;renderPillars();renderPanel();});
}

function renderPanel(){
  const s = STAGES[curStage];
  const pMeta = PILLARS.find(p=>p.key===curPillar);
  let inner = '';

  if(curPillar==='team'){
    inner = `<p class="team-desc">${s.teamDesc}</p><div class="tools">` +
      s.tools.map(t=> t.embed ? `
        <button class="tool-btn embed" onclick="openEmbedded()">
          <span class="ico">${ICON_LINK}</span>
          <span class="tnames">${t.name}<small>${t.sub}</small></span>
          ${ARROW}
        </button>` : `
        <a class="tool-btn" href="${t.url}" target="_blank" rel="noopener">
          <span class="ico">${ICON_LINK}</span>
          <span class="tnames">${t.name}<small>${t.sub}</small></span>
          ${ARROW}
        </a>`).join('') + `</div>`;
  } else {
    const d = s[curPillar];
    inner = `<p class="lead">${d.lead}</p><ul class="points">` +
      d.points.map(pt=>`<li>${pt}</li>`).join('') + `</ul>`;
    if(d.note) inner += `<div class="note ${d.warn?'warn':''}">${d.note}</div>`;
  }

  document.getElementById('panel').innerHTML = `
    <div class="p-head">
      <span class="kicker">المرحلة ${s.num} · ${s.en}</span>
      <span class="stagechip">${s.ar}</span>
    </div>
    <h2 class="p-title">${pMeta.ar}<span class="en">${pMeta.en}</span></h2>
    <div class="anim" key="${curStage}-${curPillar}">${inner}</div>`;
}

renderStages();
renderPillars();
renderPanel();
