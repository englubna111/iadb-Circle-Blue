<style>
:root{
  --ivory:#F5F2EB; --ivory-d:#ECE6DA;
  --sand:#D8CDBE;  --sand-d:#C7B9A6;
  --olive:#7F8A72; --olive-d:#6A7560; --olive-deep:#586150;
  --ink:#2F332B;   --ink-soft:#6E7468;
  --white:#FFFFFF;
  --line:rgba(47,51,43,.12); --line-soft:rgba(47,51,43,.07);
  --muted:#8A8F80;
  --shadow:0 22px 50px -26px rgba(70,75,60,.40);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{
  font-family:'Cairo',sans-serif; color:var(--ink); line-height:1.65;
  background:
    radial-gradient(130% 95% at 50% -12%, rgba(127,138,114,.16), transparent 58%),
    linear-gradient(rgba(47,51,43,.018) 1px, transparent 1px) 0 0/46px 46px,
    linear-gradient(90deg, rgba(47,51,43,.018) 1px, transparent 1px) 0 0/46px 46px,
    var(--ivory);
  min-height:100vh; padding:clamp(18px,3.5vw,48px);
}

/* Header */
.head{display:flex;align-items:center;gap:clamp(16px,2.5vw,28px);max-width:1120px;margin:0 auto clamp(20px,3vw,34px);padding-bottom:clamp(18px,2.5vw,26px);border-bottom:1px solid var(--line)}
.seal{width:clamp(96px,13vw,150px);height:auto;flex:0 0 auto;filter:drop-shadow(0 6px 16px rgba(70,75,60,.22))}
.head-text{flex:1;min-width:0}
.eyebrow{font-size:clamp(10px,1.1vw,12px);letter-spacing:.34em;font-weight:700;color:var(--olive-d);text-transform:uppercase;margin-bottom:8px}
.head-text h1{font-size:clamp(21px,3.1vw,34px);font-weight:800;line-height:1.2;letter-spacing:-.01em;color:var(--ink)}
.head-text h1 .accent{color:var(--olive)}
.pilltag{margin-top:9px;font-size:clamp(11px,1.25vw,14px);font-weight:600;color:var(--ink-soft);letter-spacing:.04em}
.pilltag span{color:var(--olive-deep);font-weight:700}

/* Stage tabs */
.wrap{max-width:1120px;margin:0 auto}
.stages{display:flex;gap:clamp(8px,1.1vw,14px);flex-wrap:wrap;margin-bottom:clamp(18px,2.6vw,30px)}
.stage{flex:1 1 165px;min-width:155px;background:var(--white);border:1px solid var(--line);border-radius:15px;padding:15px 16px;cursor:pointer;text-align:right;transition:transform .25s ease,border-color .25s ease,background .25s ease,box-shadow .25s ease;position:relative;overflow:hidden;opacity:0;transform:translateY(14px);box-shadow:0 8px 22px -18px rgba(70,75,60,.5)}
.stage::before{content:"";position:absolute;inset:0;border-radius:15px;background:linear-gradient(180deg,rgba(127,138,114,.10),transparent 70%);opacity:0;transition:opacity .25s ease}
.stage:hover{transform:translateY(-3px);border-color:var(--olive)}
.stage:hover::before{opacity:1}
.stage .num{font-size:13px;font-weight:800;color:var(--olive);letter-spacing:.12em;display:block;margin-bottom:7px}
.stage .ar{font-size:clamp(15px,1.7vw,18px);font-weight:700;line-height:1.3;color:var(--ink)}
.stage .en{font-size:11px;font-weight:600;color:var(--muted);letter-spacing:.16em;text-transform:uppercase;margin-top:4px}
.stage.active{background:linear-gradient(180deg,var(--olive),var(--olive-deep));border-color:var(--olive-deep);box-shadow:0 14px 30px -14px rgba(88,97,80,.7)}
.stage.active .num,.stage.active .en{color:var(--ivory)}
.stage.active .ar{color:var(--white)}

/* Body grid */
.board{display:grid;grid-template-columns:1fr 268px;gap:clamp(14px,2vw,24px);align-items:start}
.panel{background:var(--white);border:1px solid var(--line);border-radius:20px;padding:clamp(22px,3vw,38px);min-height:360px;box-shadow:var(--shadow);position:relative;overflow:hidden}
.panel::after{content:"";position:absolute;top:0;right:0;left:0;height:3px;background:linear-gradient(90deg,transparent,var(--olive),transparent);opacity:.8}
.pillars{display:flex;flex-direction:column;gap:10px}
.pillar{display:flex;align-items:center;gap:13px;background:var(--white);border:1px solid var(--line);border-radius:14px;padding:14px 15px;cursor:pointer;text-align:right;width:100%;color:var(--ink);font-family:inherit;transition:border-color .22s ease,background .22s ease,transform .22s ease;box-shadow:0 8px 22px -20px rgba(70,75,60,.5)}
.pillar:hover{border-color:var(--olive);transform:translateX(-3px)}
.pillar .badge{width:34px;height:34px;flex:0 0 auto;border-radius:9px;display:grid;place-items:center;font-weight:800;font-size:15px;background:var(--sand);color:var(--olive-deep);border:1px solid var(--sand-d);transition:all .22s ease}
.pillar .lab{line-height:1.25}
.pillar .lab .ar{font-size:16px;font-weight:700;display:block;color:var(--ink)}
.pillar .lab .en{font-size:10px;font-weight:600;color:var(--muted);letter-spacing:.16em;text-transform:uppercase}
.pillar.active{background:linear-gradient(180deg,var(--olive),var(--olive-deep));border-color:var(--olive-deep)}
.pillar.active .lab .ar{color:var(--white)}
.pillar.active .badge{background:var(--ivory);color:var(--olive-deep);border-color:var(--ivory)}
.pillar.active .lab .en{color:var(--ivory)}

.p-head{display:flex;align-items:center;gap:12px;margin-bottom:18px}
.p-head .kicker{font-size:11px;letter-spacing:.28em;font-weight:700;text-transform:uppercase;color:var(--olive)}
.p-head .stagechip{margin-inline-start:auto;font-size:12px;font-weight:600;color:var(--ink-soft);border:1px solid var(--line);border-radius:999px;padding:4px 13px}
.p-title{font-size:clamp(22px,2.8vw,30px);font-weight:800;margin-bottom:14px;line-height:1.25;color:var(--ink)}
.p-title .en{font-size:.5em;font-weight:600;color:var(--muted);letter-spacing:.18em;margin-inline-start:10px;text-transform:uppercase}
.lead{font-size:clamp(15px,1.7vw,17.5px);color:var(--ink);margin-bottom:18px;font-weight:500}
.points{list-style:none;display:flex;flex-direction:column;gap:11px}
.points li{position:relative;padding-right:26px;font-size:clamp(14px,1.5vw,15.5px);color:#4A4F44;font-weight:500}
.points li::before{content:"";position:absolute;right:0;top:.62em;width:9px;height:9px;border-radius:3px;background:var(--olive);box-shadow:0 0 0 4px rgba(127,138,114,.18)}
.note{margin-top:20px;padding:13px 16px;border-radius:12px;font-size:14px;font-weight:600;background:rgba(127,138,114,.12);border:1px solid rgba(127,138,114,.30);color:#454B3E}
.note.warn{background:var(--ivory-d);border-color:var(--line)}
.note b{color:var(--olive-deep)}

.team-desc{font-size:clamp(15px,1.7vw,17px);color:var(--ink);margin-bottom:22px;font-weight:500}
.tools{display:flex;flex-direction:column;gap:13px}
.tool-btn{display:flex;align-items:center;gap:14px;text-decoration:none;background:linear-gradient(180deg,var(--olive),var(--olive-deep));color:var(--ivory);border-radius:14px;padding:16px 20px;font-weight:800;font-size:clamp(15px,1.7vw,17px);transition:transform .2s ease,box-shadow .2s ease;border:1px solid var(--olive-deep)}
.tool-btn:hover{transform:translateY(-2px);box-shadow:0 16px 30px -16px rgba(88,97,80,.7)}
.tool-btn .ico{width:38px;height:38px;flex:0 0 auto;border-radius:10px;display:grid;place-items:center;background:var(--ivory);color:var(--olive-deep)}
.tool-btn .ico svg{width:19px;height:19px}
.tool-btn .tnames{display:flex;flex-direction:column;line-height:1.2;flex:1}
.tool-btn .tnames small{font-size:11px;font-weight:600;color:var(--sand);letter-spacing:.04em;margin-top:2px}
.tool-btn .arrow{margin-inline-start:auto;color:var(--ivory);transition:transform .2s ease}
.tool-btn:hover .arrow{transform:translateX(-5px)}

.foot{max-width:1120px;margin:clamp(20px,3vw,30px) auto 0;text-align:center;font-size:12px;color:var(--ink-soft);letter-spacing:.06em}
.foot b{color:var(--olive-deep)}

@keyframes rise{to{opacity:1;transform:none}}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
.anim{animation:fadeIn .4s ease both}

@media(max-width:760px){.board{grid-template-columns:1fr}.pillars{flex-direction:row;flex-wrap:wrap}.pillar{flex:1 1 130px}.pillar:hover{transform:none}}
.seal-tile{flex:0 0 auto;background:linear-gradient(160deg,var(--olive),var(--olive-deep));border-radius:20px;padding:clamp(12px,1.6vw,18px);display:grid;place-items:center;box-shadow:0 10px 26px -14px rgba(88,97,80,.6)}
.seal-tile .seal{width:clamp(70px,9vw,104px);filter:none}
button.tool-btn{width:100%;cursor:pointer;font-family:inherit;text-align:right}
.tool-btn.embed{background:linear-gradient(180deg,var(--olive-deep),#454B3E);color:var(--ivory);position:relative}
.tool-btn.embed .ico{background:var(--sand);color:var(--olive-deep)}
.tool-btn.embed .tnames small{color:var(--sand)}
.tool-btn.embed::before{content:'★';position:absolute;top:8px;left:12px;font-size:11px;color:var(--sand);opacity:.9}
</style>
